<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude Reticulum configuration and identity files from cloud backup -->
        <exclude domain="file" path=".reticulum/" />
        <exclude domain="file" path="shannon/" />
    </cloud-backup>
    <device-transfer>
        <include domain="file" path=".reticulum/" />
        <include domain="file" path="shannon/" />
    </device-transfer>
</data-extraction-rules>